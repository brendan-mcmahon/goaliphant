			"id": "get-goals-details-node",
			"name": "GET /goals (details)"
		},
		{
			"parameters": {
				"mode": "runOnceForEachItem",
				"jsCode": "const goals = $json.goals;\nconst index = $('Extract Command').item.json.argsAsIndex;\nconst goal = goals[index];\n\nif (!goal) {\n  return { text: `Goal ${index + 1} not found.` };\n}\n\nlet response = `📋 *Goal ${index + 1}*\\n`;\nresponse += `${goal.completed ? '✅' : '⬜'} ${goal.text}\\n\\n`;\n\n// Add metadata\nif (goal.dueDate) {\n  response += `📅 Due: ${goal.dueDate}\\n`;\n}\nif (goal.scheduledDate) {\n  response += `🗓️ Scheduled: ${goal.scheduledDate}\\n`;\n}\nif (goal.recurring) {\n  response += `🔄 Recurring: ${goal.recurring}\\n`;\n}\nif (goal.isHoney) {\n  response += `💕 Honey-do task\\n`;\n}\nif (goal.createdAt) {\n  response += `\\n_Created: ${new Date(goal.createdAt).toLocaleDateString()}_\\n`;\n}\n\n// Add notes\nif (goal.notes && goal.notes.length > 0) {\n  response += `\\n*Notes:*\\n`;\n  goal.notes.forEach((note, i) => {\n    const noteDate = note.createdAt ? new Date(note.createdAt).toLocaleDateString() : '';\n    response += `${i + 1}. ${note.text}${noteDate ? ` _(${noteDate})_` : ''}\\n`;\n  });\n}\n\nreturn { text: response };"
			},
			"type": "n8n-nodes-base.code",
			"typeVersion": 2,
			"position": [
				3376,
				3488
			],
