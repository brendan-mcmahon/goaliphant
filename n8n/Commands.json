			"id": "9b616c5e-7140-4f2b-bffc-75e8de38c98c",
			"name": "Switch"
		},
		{
			"parameters": {
				"jsCode": "const message = $('Telegram Trigger').first().json.message;\nlet text = message.text\nif (text[0] === '/') {\n  text = text.substring(1).trim();\n}\n\nconst command = text.split(' ')[0].toLowerCase();\nconst args = text.substring(command.length).trim();\n\n// Convert 1-based user input to 0-based API index\nconst argParts = args.split(' ');\nconst firstArg = argParts[0];\nconst secondArg = argParts[1];\nconst thirdArg = argParts[2];\nconst argsAsIndex = firstArg ? parseInt(firstArg) - 1 : null;\nconst argsAsSecondIndex = secondArg ? parseInt(secondArg) - 1 : null;\n\n// For commands like /edit 1 New text - get text after the index\nconst argsText = firstArg ? args.substring(firstArg.length).trim() : '';\n\n// Parse MM DD date format for /due and /schedule commands\nlet argsAsDate = null;\nif (secondArg && thirdArg) {\n  const month = parseInt(secondArg);\n  const day = parseInt(thirdArg);\n  if (!isNaN(month) && !isNaN(day)) {\n    const year = new Date().getFullYear();\n    const targetDate = new Date(year, month - 1, day);\n    // If date is in the past, assume next year\n    if (targetDate < new Date()) {\n      targetDate.setFullYear(year + 1);\n    }\n    argsAsDate = targetDate.toISOString().split('T')[0];\n  }\n}\n\n// Map recurring patterns to cron expressions\nlet argsAsCron = null;\nif (argsText) {\n  const pattern = argsText.toLowerCase();\n  if (pattern === 'daily') argsAsCron = '0 9 * * *';\n  else if (pattern === 'weekdays') argsAsCron = '0 9 * * 1-5';\n  else if (pattern === 'weekends') argsAsCron = '0 9 * * 0,6';\n  else if (pattern.match(/^[0-9*\\/,-]+\\s+[0-9*\\/,-]+\\s+[0-9*\\/,-]+\\s+[0-9*\\/,-]+\\s+[0-9*\\/,-]+$/)) {\n    argsAsCron = argsText; // Raw cron expression\n  }\n}\n\nreturn {\n  baseUrl: \"https://5fxpi3bue4dkhwv4kf5re3vcyi0cowqn.lambda-url.us-east-2.on.aws/api/v1\",\n  name:  message.from.first_name,\n  chatId: message.chat.id.toString(),\n  date: new Date(message.date * 1000),\n  text,\n  command,\n  args,\n  argsAsIndex,\n  argsAsSecondIndex,\n  argsText,\n  argsAsDate,\n  argsAsCron,\n}"
			},
